# ──────────────────────────────────────────────────
# FinTech OSINT Platform — Environment Configuration
# Copy to .env and fill in your values
# ──────────────────────────────────────────────────

# ── Application ──────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=replace-with-a-secure-random-string

# ── Git Hosting APIs ──────────────────────────────
GITHUB_TOKEN=ghp_your_github_personal_access_token
GITLAB_TOKEN=glpat-your_gitlab_token
BITBUCKET_USERNAME=your_bitbucket_username
BITBUCKET_APP_PASSWORD=your_bitbucket_app_password

# ── Neo4j Graph Database ──────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_secure_password
NEO4J_DATABASE=fintech

# ── Elasticsearch ─────────────────────────────────
ES_HOSTS=["http://localhost:9200"]
ES_USERNAME=
ES_PASSWORD=

# ── Anthropic AI (Conversational Interface) ───────
ANTHROPIC_API_KEY=sk-ant-your_api_key

# ── Pipeline ──────────────────────────────────────
MAX_CONCURRENT_AGENTS=4
PIPELINE_TIMEOUT_SECONDS=3600
